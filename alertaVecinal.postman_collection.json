{
  "info": {
    "name": "alertaVecinal",
    "description": "Endpoints del sistema de alerta vecinal.\n\nMejoras implementadas:\n- JWT configurable por variables de entorno\n- Soft-delete para incidentes\n- Comentarios y evidencias por incidente\n- Control de concurrencia (@Transactional)\n- RabbitMQ para eventos\n- Sin auditoria (eliminada)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tokenAdmin", "value": "" },
    { "key": "tokenVecino", "value": "" },
    { "key": "tokenPatrulla", "value": "" },
    { "key": "tokenSupervisor", "value": "" },
    { "key": "incidenteId", "value": "" },
    { "key": "patrullaId", "value": "" },
    { "key": "asignacionId", "value": "" },
    { "key": "usuarioId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var j = pm.response.json();", "pm.collectionVariables.set('tokenAdmin', j.response.token);", "pm.collectionVariables.set('usuarioId', j.response.userId);"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "1. Auth Service",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Register Vecino",
          "event": [{"listen": "test", "script": {"exec": ["var j = pm.response.json();", "pm.collectionVariables.set('tokenVecino', j.response.token);"], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"vecino1\",\n  \"password\": \"vecino123\"\n}" }
          }
        },
        {
          "name": "Listar Usuarios",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/usuarios", "host": ["{{baseUrl}}"], "path": ["api", "auth", "usuarios"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Obtener Usuario por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/usuarios/{{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api", "auth", "usuarios", "{{usuarioId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Cambiar Rol",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/auth/usuarios/{{usuarioId}}/rol", "host": ["{{baseUrl}}"], "path": ["api", "auth", "usuarios", "{{usuarioId}}", "rol"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rol\": \"ROLE_VECINO\"\n}" }
          }
        },
        {
          "name": "Bloquear/Desbloquear",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/auth/usuarios/{{usuarioId}}/bloquear", "host": ["{{baseUrl}}"], "path": ["api", "auth", "usuarios", "{{usuarioId}}", "bloquear"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/auth/usuarios/{{usuarioId}}/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "usuarios", "{{usuarioId}}", "reset-password"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nuevaPassword\": \"nuevaClave123\"\n}" }
          }
        },
        {
          "name": "Crear Supervisor",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/supervisores", "host": ["{{baseUrl}}"], "path": ["api", "auth", "supervisores"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"supervisor1\",\n  \"password\": \"super123\"\n}" }
          }
        },
        {
          "name": "Listar Supervisores",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/supervisores", "host": ["{{baseUrl}}"], "path": ["api", "auth", "supervisores"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        }
      ]
    },
    {
      "name": "2. Incident Service",
      "item": [
        {
          "name": "Crear Incidente (VECINO)",
          "event": [{"listen": "test", "script": {"exec": ["var j = pm.response.json();", "pm.collectionVariables.set('incidenteId', j.response.id);"], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/incidents", "host": ["{{baseUrl}}"], "path": ["api", "incidents"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenVecino}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"Robo\",\n  \"descripcion\": \"Robo en la cuadra 5\",\n  \"direccion\": \"Av. Principal 123\"\n}" }
          }
        },
        {
          "name": "Mis Incidentes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/incidents/mis-incidentes", "host": ["{{baseUrl}}"], "path": ["api", "incidents", "mis-incidentes"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenVecino}}" }]
          }
        },
        {
          "name": "Listar Todos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/incidents", "host": ["{{baseUrl}}"], "path": ["api", "incidents"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Obtener por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/incidents/{{incidenteId}}", "host": ["{{baseUrl}}"], "path": ["api", "incidents", "{{incidenteId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Actualizar Incidente",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/incidents/{{incidenteId}}", "host": ["{{baseUrl}}"], "path": ["api", "incidents", "{{incidenteId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"Robo\",\n  \"descripcion\": \"Actualizado: robo con arma blanca\",\n  \"direccion\": \"Av. Principal 123\",\n  \"estado\": \"PENDIENTE\"\n}" }
          }
        },
        {
          "name": "Eliminar Incidente (soft-delete)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/incidents/{{incidenteId}}", "host": ["{{baseUrl}}"], "path": ["api", "incidents", "{{incidenteId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        }
      ]
    },
    {
      "name": "3. Patrullas",
      "item": [
        {
          "name": "Crear Patrulla",
          "event": [{"listen": "test", "script": {"exec": ["var j = pm.response.json();", "pm.collectionVariables.set('patrullaId', j.response.id);", "console.log('Username: ' + j.response.username + ' / Password: ' + j.response.password);"], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/patrullas", "host": ["{{baseUrl}}"], "path": ["api", "patrullas"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"codigo\": \"PAT001\",\n  \"nombre\": \"Patrulla Norte 01\",\n  \"sector\": \"Zona Norte\"\n}" }
          }
        },
        {
          "name": "Listar Patrullas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/patrullas", "host": ["{{baseUrl}}"], "path": ["api", "patrullas"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Obtener Patrulla",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/patrullas/{{patrullaId}}", "host": ["{{baseUrl}}"], "path": ["api", "patrullas", "{{patrullaId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Actualizar Patrulla",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/patrullas/{{patrullaId}}", "host": ["{{baseUrl}}"], "path": ["api", "patrullas", "{{patrullaId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"codigo\": \"PAT001\",\n  \"nombre\": \"Patrulla Norte - Actualizada\",\n  \"sector\": \"Zona Norte\"\n}" }
          }
        },
        {
          "name": "Eliminar Patrulla (soft-delete)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/patrullas/{{patrullaId}}", "host": ["{{baseUrl}}"], "path": ["api", "patrullas", "{{patrullaId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        }
      ]
    },
    {
      "name": "4. Asignaciones",
      "item": [
        {
          "name": "Asignar Incidente a Patrulla",
          "event": [{"listen": "test", "script": {"exec": ["var j = pm.response.json();", "pm.collectionVariables.set('asignacionId', j.response.id);"], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/asignaciones", "host": ["{{baseUrl}}"], "path": ["api", "asignaciones"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"incidenteId\": {{incidenteId}},\n  \"patrullaId\": {{patrullaId}}\n}" }
          }
        },
        {
          "name": "Listar Asignaciones",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/asignaciones", "host": ["{{baseUrl}}"], "path": ["api", "asignaciones"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Obtener Asignación",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/asignaciones/{{asignacionId}}", "host": ["{{baseUrl}}"], "path": ["api", "asignaciones", "{{asignacionId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Reasignar Incidente",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/asignaciones/{{asignacionId}}/reasignar", "host": ["{{baseUrl}}"], "path": ["api", "asignaciones", "{{asignacionId}}", "reasignar"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nuevaPatrullaId\": 2\n}" }
          }
        }
      ]
    },
    {
      "name": "5. Serenazgo Operativo",
      "item": [
        {
          "name": "Listar Incidentes (proxy)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Mis Incidentes (SERENAZGO)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/mis-incidentes", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "mis-incidentes"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenPatrulla}}" }]
          }
        },
        {
          "name": "Obtener Incidente",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Estado → EN_PROCESO",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/estado?serenazgoId={{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "estado"], "query": [{"key": "serenazgoId", "value": "{{usuarioId}}"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nuevoEstado\": \"EN_PROCESO\"\n}" }
          }
        },
        {
          "name": "Estado → ATENDIDO",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/estado?serenazgoId={{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "estado"], "query": [{"key": "serenazgoId", "value": "{{usuarioId}}"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nuevoEstado\": \"ATENDIDO\"\n}" }
          }
        },
        {
          "name": "Estado → CERRADO",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/estado?serenazgoId={{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "estado"], "query": [{"key": "serenazgoId", "value": "{{usuarioId}}"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nuevoEstado\": \"CERRADO\"\n}" }
          }
        },
        {
          "name": "Historial de Estados",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/historial", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "historial"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Agregar Comentario",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/comentarios", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "comentarios"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"comentario\": \"Patrulla inspeccionando la zona\"\n}" }
          }
        },
        {
          "name": "Listar Comentarios",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/comentarios", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "comentarios"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Subir Evidencia (form-data)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/evidencias", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "evidencias"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "archivo", "type": "file", "src": [] }] }
          }
        },
        {
          "name": "Listar Evidencias",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/serenazgo/incidentes/{{incidenteId}}/evidencias", "host": ["{{baseUrl}}"], "path": ["api", "serenazgo", "incidentes", "{{incidenteId}}", "evidencias"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        }
      ]
    },
    {
